{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.athena",
  "name": "Athena Connector",
  "version": "0.1.3",
  "publisher": "irodori",
  "description": "Athena Connector contributes the Athena database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-athena",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "athena.connector",
        "engine": "athena",
        "label": "Athena",
        "aliases": [
          "athena",
          "Amazon Athena",
          "Athena"
        ],
        "defaultPort": 443,
        "wire": "lakehouse",
        "module": "athena.driver",
        "features": [
          "metadata",
          "sql"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "athena",
            "wire": "lakehouse",
            "port": 443,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "cloudResource",
              "customEndpoint",
              "connectionString"
            ],
            "defaultPort": 443,
            "fields": [
              {
                "id": "region",
                "label": "AWS region",
                "type": "string",
                "option": "region",
                "required": true
              },
              {
                "id": "catalog",
                "label": "Catalog",
                "type": "string",
                "option": "Catalog",
                "default": "AwsDataCatalog"
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database",
                "option": "Database",
                "default": "default"
              },
              {
                "id": "workgroup",
                "label": "Workgroup",
                "type": "string",
                "option": "WorkGroup",
                "default": "primary"
              },
              {
                "id": "outputLocation",
                "label": "S3 output location",
                "type": "uri",
                "option": "OutputLocation"
              },
              {
                "id": "endpoint",
                "label": "Custom endpoint",
                "type": "uri",
                "profileField": "host"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "region",
              "label": "AWS region",
              "type": "string",
              "option": "region",
              "required": true
            },
            {
              "id": "catalog",
              "label": "Catalog",
              "type": "string",
              "option": "Catalog",
              "default": "AwsDataCatalog"
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database",
              "option": "Database",
              "default": "default"
            },
            {
              "id": "workgroup",
              "label": "Workgroup",
              "type": "string",
              "option": "WorkGroup",
              "default": "primary"
            },
            {
              "id": "outputLocation",
              "label": "S3 output location",
              "type": "uri",
              "option": "OutputLocation"
            },
            {
              "id": "endpoint",
              "label": "Custom endpoint",
              "type": "uri",
              "profileField": "host"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "awsDefaultCredentialsChain",
              "label": "AWS default credential chain",
              "kind": "iam",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsSigV4",
              "label": "AWS SigV4",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "accessKeyId",
                  "label": "Access key ID",
                  "type": "string"
                },
                {
                  "id": "secretAccessKey",
                  "label": "Secret access key",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "sessionToken",
                  "label": "Session token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsProfile",
              "label": "AWS shared config profile",
              "kind": "iam",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "profile",
                  "label": "Profile",
                  "type": "string",
                  "option": "awsProfile"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsSso",
              "label": "AWS IAM Identity Center / SSO",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "ssoSession",
                  "label": "SSO session",
                  "type": "string",
                  "option": "ssoSession"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "webIdentity",
              "label": "AWS web identity",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "roleArn",
                  "label": "Role ARN",
                  "type": "string",
                  "option": "roleArn"
                },
                {
                  "id": "webIdentityToken",
                  "label": "Web identity token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "awsAssumeRole",
              "label": "AWS STS assume role",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "roleArn",
                  "label": "Role ARN",
                  "type": "string",
                  "option": "roleArn",
                  "required": true
                },
                {
                  "id": "externalId",
                  "label": "External ID",
                  "type": "string",
                  "option": "externalId"
                },
                {
                  "id": "sessionName",
                  "label": "Session name",
                  "type": "string",
                  "option": "sessionName"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "sessionToken",
              "label": "AWS session token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "token",
            "password",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": true,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "lakehouse",
            "athena",
            "aws",
            "catalog",
            "objectStorage"
          ],
          "customDriverOptions": true
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "athena.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
