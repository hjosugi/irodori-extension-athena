{
  "schemaVersion": 1,
  "extensionId": "irodori.athena",
  "visibility": "public",
  "version": "0.1.3",
  "connector": {
    "id": "athena.connector",
    "engine": "athena",
    "label": "Athena",
    "aliases": [
      "athena",
      "Amazon Athena",
      "Athena"
    ],
    "defaultPort": 443,
    "wire": "lakehouse",
    "module": "athena.driver",
    "features": [
      "metadata",
      "sql"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "cloudResource",
        "customEndpoint",
        "connectionString"
      ],
      "defaultPort": 443,
      "fields": [
        {
          "id": "region",
          "label": "AWS region",
          "type": "string",
          "option": "region",
          "required": true
        },
        {
          "id": "catalog",
          "label": "Catalog",
          "type": "string",
          "option": "Catalog",
          "default": "AwsDataCatalog"
        },
        {
          "id": "database",
          "label": "Database",
          "type": "string",
          "profileField": "database",
          "option": "Database",
          "default": "default"
        },
        {
          "id": "workgroup",
          "label": "Workgroup",
          "type": "string",
          "option": "WorkGroup",
          "default": "primary"
        },
        {
          "id": "outputLocation",
          "label": "S3 output location",
          "type": "uri",
          "option": "OutputLocation"
        },
        {
          "id": "endpoint",
          "label": "Custom endpoint",
          "type": "uri",
          "profileField": "host"
        }
      ]
    },
    "authMethods": [
      "none",
      "connectionString",
      "awsDefaultCredentialsChain",
      "awsSigV4",
      "awsProfile",
      "awsSso",
      "webIdentity",
      "awsAssumeRole",
      "sessionToken",
      "customDriverOptions"
    ],
    "tls": "required",
    "transports": "default",
    "optionNamespaces": [
      "lakehouse",
      "athena",
      "aws",
      "catalog",
      "objectStorage"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": true
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  }
}
